# Ignore the models directory by default if it exists, as it may contain secrets
models/**
# But allow safe, curated content in the models directory
!models/**/
!models/**/README.md
!models/**/notes/**
!models/**/config/**
!models/**/templates/**
# Re-ignore machine/runtime artifacts inside otherwise allowed config trees
models/**/config/config.json
models/**/config/logs/**
models/**/config/telemetry/**
models/**/config/**/*.jsonl
models/**/config/**/*session*.json
models/**/config/**/*session*.jsonl
# Never commit prompts (may contain secrets)
models/**/prompts/**
!models/**/prompts/README.md


